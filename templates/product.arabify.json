{"sections":{"multi_content_hCCUfG":{"type":"multi-content","blocks":{"image_9zHFNb":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Main-Banner-min-uai-720x720.png","image_behavior":"none","image_link":"","content_width":"50%","vertical_align":"start"}},"text_rw4PUe":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"50%","vertical_align":"center","image_link":"","subheading":"","heading":"<div style=\"line-height:1.6; font-weight:600;\">\n  <span style=\"color:#95BE45;\">إنـطـلـق <\/span>بـمـتـجـرك الإلـكـتـرونـي بـسـهـولـة واحتـرافـيـة 🚀\n<\/div>","description":"<p style=\"line-height:1.9; font-weight:500;\">\nمـع <strong>قـالـب عـربـيـفـاي<\/strong>، نـضـع بـيـن يـديـك الـحـل الأمـثـل لـبـنـاء مـتـجـر إلـكـتـرونـي مـتـكـامـل يـلـيـق بـطـمـوحـك. يـمـنـحـك الـقـالـب تـصـمـيـمـاً عـصـريـاً يـدعـم الـلـغـة الـعـربـيـة بـاحـتـرافـيـة مـطـلـقـة، مـع تـركـيـز فـائـق عـلـى سـرعـة الأداء وتـجـربـة الـمـسـتـخـدم الـسـلـسـة عـبـر جـمـيـع الأجـهـزة. لـقـد صـمـمـنـا <strong>عـربـيـفـاي<\/strong> لـيـكـون سـهـل الـتـخـصـيـص ومـهـيـأً بـالـكـامـل لـمـحـركـات الـبـحث، لـتـتـمـكـن مـن الإنـطـلاق بـمـشـروعـك الـرقـمـي بـثـقـة، كـفـاءة، واحـتـرافـيـة عـالـيـة.\n<\/p>","collection":"","timer":"","expired_message":"Time expired","style":"default","font_size":46,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":20,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":45,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":19,"des_font_weight":"body_weight","des_spacing_bottom":30}}},"block_order":["image_9zHFNb","text_rw4PUe"],"name":"t:sections.multi_content.name","settings":{"section_width":"full_width","heading":"","description":"","header_size":"medium","header_alignment":"cent