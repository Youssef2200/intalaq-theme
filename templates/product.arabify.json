m top of viewport if you want\n      const imageTopDoc = originalTop + window.scrollY + sectionRect.top;\n      const textTopDoc = textRect.top + window.scrollY;\n      const textBottomDoc = textTopDoc + textRect.height;\n\n      let start = imageTopDoc - topOffset;\n      let end = textBottomDoc - topOffset - imgHeight;\n      if (end < start) end = start;\n      const maxTranslate = Math.max(0, end - start);\n\n      function updatePosition() {\n        const y = window.scrollY;\n        let translate;\n        if (y <= start) translate = 0;\n        else if (y >= end) translate = maxTranslate;\n        else translate = y - start;\n\n        imageBlock.style.top = (originalTop + translate) + 'px';\n      }\n\n      function onScrollRAF() {\n        if (state.raf) return;\n        state.raf = requestAnimationFrame(function () {\n          updatePosition();\n          state.raf = null;\n        });\n      }\n\n      \/\/ initial position\n      updatePosition();\n\n      \/\/ listeners\n      window.addEventListener('scroll', onScrollRAF, { passive: true });\n      window.addEventListener('resize', recalc, { passive: true });\n\n      function recalc() {\n        \/\/ cleanup and re-run full setup so geometry is correct\n        teardown();\n        setup();\n      }\n\n      \/\/ cleanup closure\n      state.cleanup = function () {\n        window.removeEventListener('scroll', onScrollRAF);\n        window.removeEventListener('resize', recalc);\n        if (state.raf) {\n          cancelAnimationFrame(state.raf);\n          state.raf = null;\n        }\n        \/\/ restore node state\n        try {\n          if (placeholder && placeholder.parentNode) placeholder.parentNode.removeChild(placeholder);\n          imageBlock.classList.remove('intalaq-abs');\n          imageBlock.style.position = '';\n          imageBlock.style.top = '';\n          imageBlock.style.left = '';\n          imageBlock.style.width = '';\n          imageBlock.style.boxSizing = '';\n         