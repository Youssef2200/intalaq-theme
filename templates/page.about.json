,"rich_text_qMbJGD":{"type":"rich-text","blocks":{"heading_KrjGD4":{"type":"heading","settings":{"heading":"إنـطـلـق بـثـقـة تـامـة.. وابـدأ مـشـروع أحـلامـك الـيـوم.","font_size":36,"font_weight":"heading_weight","uppercase":false,"spacing_bottom":24}}},"block_order":["heading_KrjGD4"],"settings":{"section_width":"container","color_scheme":"","content_alignment":"center","content_max_width":90,"enable_expand_content":false,"expand_content_button":"See all Information","padding_top":0,"padding_bottom":80,"reset_spacing":false}},"divider_jTBGQJ":{"type":"divider","disabled":true,"settings":{"section_width":"container","border_height":1,"border_color":"#ebebeb","reset_spacing":false}},"multi_content_9ADpDi":{"type":"multi-content","blocks":{"text_CGzHyR":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"50%","vertical_align":"start","image_link":"","subheading":"غذاء صحي ونمط حياة مثالي.","heading":"شنو مكونات أكلنا؟","description":"<p>نحرص على تقديم مجموعة مختارة من المنتجات الطبيعية اللي نقوم بتحضيرها بعناية من أجود أنواع المكسرات، والحبوب الكاملة، والتمور الفاخرة، والكثير من المكونات الصحية.<\/p>","collection":"","timer":"","expired_message":"Time expired","style":"default","font_size":46,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"center","subheading_font_size":18,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":45,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":19,"des_font_weight":"body_weight","des_spacing_bottom":30}},"image_BgGJTR":{"type":"image","settings":{"image_behavior":"none","image_link":"","content_width":"50%","vertical_align":"start"}}},"block_order":["text_CGzHyR","image_BgGJTR"],"disabled":true,"name":"t:sections.multi_content.name","settings":{"section_width":"fluid_container","heading":"","description":"","header_size":"medium","header_alignment":"center","column_gap":30,"content_background_color":"","equal_height_adjustment":false,"carousel_on_mobile":false,"items_per_row_mobile":1,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"multi_content_VbbiBa":{"type":"multi-content","blocks":{"text_Rw4VBA":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"50%","vertical_align":"start","image_link":"","subheading":"","heading":"رسالتنا","description":"<p>رسالتنا في OraCare تنبع من إيماننا العميق بأن كل امرأة تستحق أن تُعامل كأنها الأهم.<br\/><br\/>نلتزم بتوفير منتجات عالية الجودة، مختارة بعناية فائقة، تضمن لكِ نتائج فعالة وآمنة دون تنازل عن الفخامة أو الراحة.<br\/><br\/>نسعى لأن نكون جزءًا من روتينك اليومي، ونمنحك شعورًا دائمًا بالاهتمام، والثقة، والرعاية الذاتية.<br\/><br\/>نريدك أن تشعري بأن كل منتج يصل إلى يديكِ هو امتداد لاهتمامنا بكِ، وتأكيد على أنك محور اهتمامنا.<\/p>","collection":"","timer":"","expired_message":"","style":"default","font_size":36,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":12,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":36,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":18,"des_font_weight":"body_weight","des_spacing_bottom":0}},"text_UTJEDt":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"50%","vertical_align":"start","image_link":"","subheading":"","heading":"رؤيتنا","description":"<p>رؤيتنا هي بناء مجتمع نسائي واثق، واعٍ، يختار الأفضل لنفسه دون تردد.<br\/><br\/>نسعى لأن نصبح وجهتك الأولى في عالم العناية الشخصية، ليس فقط كمصدر للمنتجات، بل كشريك في رحلتك نحو نمط حياة صحي، أنيق، ومتوازن.<br\/><br\/>نطمح إلى توسيع نطاقنا وتقديم محتوى توعوي وتجريبي يجعل كل زيارة إلى OraCare تجربة ملهمة ومليئة بالقيمة.<br\/><br\/>في عالم سريع التغير، نؤمن بأن الثبات على الجودة والصدق هو ما يميزنا، وهذا ما ستجدينه معنا دائمًا.<\/p>","collection":"","timer":"","expired_message":"","style":"default","font_size":36,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":12,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":36,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":18,"des_font_weight":"body_weight","des_spacing_bottom":0}}},"block_order":["text_Rw4VBA","text_UTJEDt"],"disabled":true,"settings":{"section_width":"container","heading":"","description":"","header_size":"medium","header_alignment":"center","column_gap":30,"content_background_color":"","equal_height_adjustment":false,"carousel_on_mobile":false,"items_per_row_mobile":1,"padding_top":0,"padding_bottom":0,"reset_spacing":true}}},"order":["page-heading","rich_text_Jce37K","multi_content_t6yxDU","rich_text_qMbJGD","divider_jTBGQJ","multi_content_9ADpDi","multi_content_VbbiBa"]}