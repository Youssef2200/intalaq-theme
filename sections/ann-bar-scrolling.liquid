{%- style -%}
.section-{{ section.id }}-padding {
padding-top: 14px;
padding-bottom: 14px;
}
@media screen and (min-width: 750px) {
.section-{{ section.id }}-padding {
padding-top:14px;
padding-bottom:14px;
}
}
{%- endstyle -%}
{% assign rtl_locales = 'ar,fa,he,ur,ku,ps,sd,dv,syr,ug,yi' %}
<div class="scrolling-box-{{ section.id }} section-{{ section.id }}-padding {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="marquee-{{ section.id }}">
     <div class="marquee-content-{{ section.id }}">
        {%- for block in section.blocks -%}
         {% if settings.rtl_ltr_direction == 'auto' and rtl_locales contains shop.locale %}
              <div class="marquee-tag-{{ section.id }} announcement-marquee-tag-{{ section.id }}">
                 &nbsp;&nbsp;&nbsp;{{ block.settings.marquee_text }}&nbsp;
                 {{ block.settings.icon }}
              </div>
           {% else %}
              <div class="marquee-tag-{{ section.id }} announcement-marquee-tag-{{ section.id }}">
                 {{ block.settings.icon }}
                 &nbsp;{{ block.settings.marquee_text }}&nbsp;&nbsp;&nbsp;
              </div>
