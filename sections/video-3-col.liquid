{% schema %}
{
  "name": "Vidéo et texte 3-col",
  "settings": [
    {
      "type": "header",
      "content": "Ajoutez des vidéos et un texte d'accompagnement"
    },
    {
      "type": "video",
      "id": "video_file_1",
      "label": "Vidéo 1 (Shopify)"
    },
    {
      "type": "url",
      "id": "video_url_1",
      "label": "URL de la vidéo 1"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay_1",
      "label": "Lecture automatique de la vidéo 1",
      "default": true
    },
    {
      "type": "text",
      "id": "video_title_1",
      "label": "Titre de la vidéo 1",
      "default": "Titre 1"
    },
    {
      "type": "text",
      "id": "video_width_1",
      "label": "Largeur de la vidéo 1 (desktop)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur desktop (ex: '100%' ou '800px')"
    },
    {
      "type": "text",
      "id": "video_width_mobile_1",
      "label": "Largeur de la vidéo 1 (mobile)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur mobile (ex: '100%' ou '300px')"
    },
    {
      "type": "text",
      "id": "video_height_1",
      "label": "Hauteur de la vidéo 1",
      "default": "auto",
      "info": "Définissez la hauteur de la vidéo (ex: 'auto' ou '450px')"
    },
    {
      "type": "product",
      "id": "selected_product_1",
      "label": "Sélectionnez un produit à afficher"
    },
    {
      "type": "video",
      "id": "video_file_2",
      "label": "Vidéo 2 (Shopify)"
    },
    {
      "type": "url",
      "id": "video_url_2",
      "label": "URL de la vidéo 2"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay_2",
      "label": "Lecture automatique de la vidéo 2",
      "default": true
    },
    {
      "type": "text",
      "id": "video_title_2",
      "label": "Titre de la vidéo 2",
      "default": "Titre 2"
    },
    {
      "type": "text",
      "id": "video_width_2",
      "label": "Largeur de la vidéo 2 (desktop)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur desktop (ex: '100%' ou '800px')"
    },
    {
      "type": "text",
      "id": "video_width_mobile_2",
      "label": "Largeur de la vidéo 2 (mobile)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur mobile (ex: '100%' ou '300px')"
    },
    {
      "type": "text",
      "id": "video_height_2",
      "label": "Hauteur de la vidéo 2",
      "default": "auto",
      "info": "Définissez la hauteur de la vidéo (ex: 'auto' ou '450px')"
    },
    {
      "type": "product",
      "id": "selected_product_2",
      "label": "Sélectionnez un produit à afficher"
    },
    {
      "type": "video",
      "id": "video_file_3",
      "label": "Vidéo 3 (Shopify)"
    },
    {
      "type": "url",
      "id": "video_url_3",
      "label": "URL de la vidéo 3"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay_3",
      "label": "Lecture automatique de la vidéo 3",
      "default": true
    },
    {
      "type": "text",
      "id": "video_title_3",
      "label": "Titre de la vidéo 3",
      "default": "Titre 3"
    },
    {
      "type": "text",
      "id": "video_width_3",
      "label": "Largeur de la vidéo 3 (desktop)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur desktop (ex: '100%' ou '800px')"
    },
    {
      "type": "text",
      "id": "video_width_mobile_3",
      "label": "Largeur de la vidéo 3 (mobile)",
      "default": "100%",
      "info": "Définissez la largeur de la vidéo sur mobile (ex: '100%' ou '300px')"
    },
    {
      "type": "text",
      "id": "video_height_3",
      "label": "Hauteur de la vidéo 3",
      "default": "auto",
      "info": "Définissez la hauteur de la vidéo (ex: 'auto' ou '450px')"
    },
    {
      "type": "product",
      "id": "selected_product_3",
      "label": "Sélectionnez un produit à afficher"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Texte d'accompagnement",
      "default": "<p>Voici un texte d'accompagnement pour les vidéos.</p>"
    }
  ],
  "presets": [
    {
      "name": "Vidéo et texte 3",
      "category": "Contenu"
    }
  ]
}
{% endschema %}

<section class="video-et-texte">
  <div class="three-columns">
    {% for i in (1..3) %}
      {% capture video_key %}video_file_{{ i }}{% endcapture %}
      {% capture url_key %}video_url_{{ i }}{% endcapture %}
      {% capture autoplay_key %}video_autoplay_{{ i }}{% endcapture %}
      {% capture title_key %}video_title_{{ i }}{% endcapture %}
      {% assign video_file = section.settings[video_key] %}
      {% assign video_url = section.settings[url_key] %}
      {% assign video_autoplay = section.settings[autoplay_key] %}
      {% assign video_title = section.settings[title_key] %}
      
      <div class="column video-column">
        <h2 class="video-title">{{ video_title }}</h2>
        <div class="video-container">
          {% if video_file != blank %}
            <video class="video-player" {% if video_autoplay %}autoplay{% endif %} loop muted controls>
              <source src="{{ video_file | file_url }}" type="video/mp4">
              Votre navigateur ne supporte pas la lecture de vidéo.
            </video>
          {% elsif video_url != blank %}
            <video class="video-player" {% if video_autoplay %}autoplay{% endif %} loop muted controls>
              <source src="{{ video_url }}" type="video/mp4">
              Votre navigateur ne supporte pas la lecture de vidéo.
            </video>
          {% else %}
            <p>Aucune vidéo ajoutée.</p>
          {% endif %}
        </div>

        {% assign product_key = 'selected_product_' | append: i %}
        {% assign product_id = section.settings[product_key] %}
        
        {% if product_id %}
          {% assign product = all_products[product_id] %}
          
          {% if product %}
            <div class="product-details">
              <h3>{{ product.title }}</h3>
              
{% if product.variants.size > 0 %}
  {% assign first_variant = product.variants.first %}
  {% if first_variant.featured_image %}
    <img src="{{ first_variant.featured_image | img_url: '500x500' }}" alt="{{ first_variant.title }}">
  {% else %}
    <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title }}">
  {% endif %}
  <p>{{ first_variant.price | money }}</p>
  <a href="{{ first_variant.url }}" class="btn">Choisir ma taille</a>
{% else %}
  <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title }}">
  <p>{{ product.price | money }}</p>
  <a href="{{ product.url }}" class="btn">Voir le produit</a>
{% endif %}
            </div>
          {% else %}
            <p>Produit non trouvé.</p>
          {% endif %}
        {% else %}
          <p>Aucun produit sélectionné pour cette colonne.</p>
        {% endif %}
      </div>
    {% endfor %}
    <div class="column text-column">
      <div class="text-content">{{ section.settings.text_content }}</div>
    </div>
  </div>
</section>

<style>
  .video-et-texte {
    max-width: 80%;
    margin: 0 auto;
    padding: 20px;
  }
  .video-et-texte .three-columns {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 20px;
  }
  .video-et-texte .column {
    flex: 1 1 30%;
    box-sizing: border-box;
    padding: 20px;
  }
  .video-et-texte .video-container {
    text-align: center;
  }
  .video-et-texte .video-player {
    max-width: 100%;
    height: auto;
  }
  .video-et-texte .product-details {
    text-align: center;
    margin-top: 20px;
  }
  .video-et-texte .product-details img {
    max-width: 80%;
    height: auto;
  }
  .video-et-texte .product-details .btn {
    display: inline-block;
    background-color: #414141;
    color: #fff;
    padding: 10px 20px;
    text-decoration: none;
    border-radius: 5px;
    margin-top: 10px;
  }
  @media (max-width: 768px) {
    .video-et-texte .three-columns {
      flex-direction: column;
    }
    .video-et-texte .column {
      flex: 1 1 100%;
    }
  }
</style>


